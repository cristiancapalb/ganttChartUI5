{
  "_version": "1.83.0",
  "sap.app": {
    "id": "ganttchartdemo",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "c89f750b-60d3-452e-9104-5b0ee6c42f61"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.table": {},
        "sap.gantt": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ganttchartdemo.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "ganttchartdemo.view",
        "async": true,
        "viewPath": "ganttchartdemo.view"
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": ":?query:",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "RouteEmployeeGantt",
          "pattern": "employee-gantt",
          "target": [
            "TargetEmployeeGantt"
          ]
        },
        {
          "name": "RouteProfileOverview",
          "pattern": "profile-overview",
          "target": [
            "TargetProfileOverview"
          ]
        },
        {
          "name": "RouteProfileDetail",
          "pattern": "profile-overview/{employeeId}",
          "target": [
            "TargetProfileDetail"
          ]
        },
        {
          "name": "RouteProjectConfiguration",
          "pattern": "project-configuration",
          "target": [
            "TargetProjectConfiguration"
          ]
        },
        {
          "name": "RouteProjectEdit",
          "pattern": "project-configuration/{projectId}",
          "target": [
            "TargetProjectEdit"
          ]
        }
      ],
      "targets": {
        "TargetHome": {
          "id": "Home",
          "name": "Home"
        },
        "TargetganttChart": {
          "id": "ganttChart",
          "name": "ganttChart"
        },
        "TargetEmployeeGantt": {
          "id": "EmployeeGantt",
          "name": "EmployeeGantt"
        },
        "TargetProfileOverview": {
          "id": "ProfileOverview",
          "name": "ProfileOverview"
        },
        "TargetProfileDetail": {
          "id": "ProfileDetail",
          "name": "ProfileDetail"
        },
        "TargetProjectConfiguration": {
          "id": "ProjectConfiguration",
          "name": "ProjectConfiguration"
        },
        "TargetProjectEdit": {
          "id": "ProjectEdit",
          "name": "ProjectEdit"
        }
      }
    },
    "rootView": {
      "viewName": "ganttchartdemo.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
