<mvc:View
    controllerName="ganttchartdemo.controller.ProjectEdit"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page
        id="projectEditPage"
        title="{project>/name}"
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiResponsiveContentPadding">
        <content>
            <VBox
                class="homeDetailPage sapUiSmallMargin"
                renderType="Bare">
                <Panel
                    headerText="{i18n>projectEditGeneralTitle}"
                    width="100%">
                    <VBox
                        class="projectConfigurationForm"
                        renderType="Bare">
                        <Label
                            text="{i18n>projectConfigurationNameLabel}"
                            labelFor="projectEditNameInput"/>
                        <Input
                            id="projectEditNameInput"
                            value="{project>/name}"
                            width="100%"/>
                        <Label
                            text="{i18n>projectEditOwnerLabel}"
                            labelFor="projectEditOwnerInput"
                            class="sapUiSmallMarginTop"/>
                        <Input
                            id="projectEditOwnerInput"
                            value="{project>/owner}"
                            width="100%"/>
                        <Label
                            text="{i18n>projectEditStatusLabel}"
                            labelFor="projectEditStatusSelect"
                            class="sapUiSmallMarginTop"/>
                        <Select
                            id="projectEditStatusSelect"
                            selectedKey="{project>/status}"
                            width="100%">
                            <items>
                                <core:Item
                                    key="confirmed"
                                    text="{i18n>projectEditStatusConfirmed}"/>
                                <core:Item
                                    key="tentative"
                                    text="{i18n>projectEditStatusTentative}"/>
                                <core:Item
                                    key="planned"
                                    text="{i18n>projectEditStatusPlanned}"/>
                            </items>
                        </Select>
                        <Label
                            text="{i18n>projectEditStartDateLabel}"
                            labelFor="projectEditStartDate"
                            class="sapUiSmallMarginTop"/>
                        <DatePicker
                            id="projectEditStartDate"
                            value="{project>/startDate}"
                            valueFormat="yyyy-MM-dd"
                            displayFormat="medium"
                            width="100%"/>
                        <Label
                            text="{i18n>projectEditEndDateLabel}"
                            labelFor="projectEditEndDate"
                            class="sapUiSmallMarginTop"/>
                        <DatePicker
                            id="projectEditEndDate"
                            value="{project>/endDate}"
                            valueFormat="yyyy-MM-dd"
                            displayFormat="medium"
                            width="100%"/>
                        <Label
                            text="{i18n>projectConfigurationTimelineLabel}"
                            labelFor="projectEditTimelineModeSelect"
                            class="sapUiSmallMarginTop"/>
                        <Select
                            id="projectEditTimelineModeSelect"
                            selectedKey="{project>/timelineScale}"
                            width="100%">
                            <items>
                                <core:Item
                                    key="month"
                                    text="{i18n>projectConfigurationTimelineMonth}"/>
                                <core:Item
                                    key="week"
                                    text="{i18n>projectConfigurationTimelineWeek}"/>
                                <core:Item
                                    key="day"
                                    text="{i18n>projectConfigurationTimelineDay}"/>
                            </items>
                        </Select>
                        <Label
                            text="{i18n>projectConfigurationCapacityLabel}"
                            labelFor="projectEditCapacityInput"
                            class="sapUiSmallMarginTop"/>
                        <StepInput
                            id="projectEditCapacityInput"
                            value="{project>/capacityThreshold}"
                            min="1"
                            max="200"
                            step="5"
                            width="12rem"/>
                        <HBox
                            alignItems="Center"
                            class="sapUiSmallMarginTop">
                            <Switch
                                id="projectEditWeekendSwitch"
                                state="{project>/includeWeekends}"/>
                            <Text
                                text="{i18n>projectConfigurationWeekendText}"
                                class="sapUiTinyMarginBegin"/>
                        </HBox>
                    </VBox>
                </Panel>
            </VBox>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button
                    text="{i18n>projectEditCancelButton}"
                    press=".onNavBack"/>
                <Button
                    text="{i18n>projectConfigurationSaveButton}"
                    type="Emphasized"
                    press=".onSave"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
