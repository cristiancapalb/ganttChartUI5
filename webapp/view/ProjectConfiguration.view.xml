<mvc:View
    controllerName="ganttchartdemo.controller.ProjectConfiguration"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page
        id="projectConfigurationPage"
        title="{i18n>projectConfigurationTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiResponsiveContentPadding">
        <content>
            <VBox
                class="homeDetailPage sapUiSmallMargin"
                renderType="Bare">
                <Table
                    id="projectOverviewTable"
                    width="100%"
                    mode="None"
                    growing="true"
                    growingScrollToLoad="true"
                    items="{projects>/projects}">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title
                                text="{i18n>projectConfigurationOverviewTitle}"
                                level="H2"/>
                            <ToolbarSpacer/>
                            <SearchField
                                id="projectSearchField"
                                width="18rem"
                                placeholder="{i18n>projectConfigurationSearchPlaceholder}"
                                liveChange=".onFilterProjects"
                                search=".onFilterProjects"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column>
                            <Text text="{i18n>projectConfigurationProjectColumn}"/>
                        </Column>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true">
                            <Text text="{i18n>projectConfigurationOwnerColumn}"/>
                        </Column>
                        <Column
                            minScreenWidth="Desktop"
                            demandPopin="true">
                            <Text text="{i18n>projectConfigurationDatesColumn}"/>
                        </Column>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true">
                            <Text text="{i18n>projectConfigurationCapacityColumn}"/>
                        </Column>
                        <Column hAlign="End">
                            <Text text="{i18n>projectConfigurationActionsColumn}"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem
                            type="Inactive"
                            vAlign="Middle">
                            <cells>
                                <VBox renderType="Bare">
                                    <Text
                                        text="{projects>name}"
                                        wrapping="false"/>
                                    <ObjectStatus
                                        text="{path: 'projects>status', formatter: '.formatStatusText'}"
                                        state="{path: 'projects>status', formatter: '.formatStatusState'}"/>
                                </VBox>
                                <Text text="{projects>owner}"/>
                                <Text
                                    text="{
                                        parts: [
                                            {path: 'projects>startDate'},
                                            {path: 'projects>endDate'}
                                        ],
                                        formatter: '.formatDateRange'
                                    }"/>
                                <ObjectNumber
                                    number="{projects>capacityThreshold}"
                                    unit="%"/>
                                <Button
                                    icon="sap-icon://edit"
                                    tooltip="{i18n>projectConfigurationEditTooltip}"
                                    type="Transparent"
                                    press=".onEditProject">
                                    <customData>
                                        <core:CustomData
                                            key="project-id"
                                            value="{projects>id}"
                                            writeToDom="true"/>
                                    </customData>
                                </Button>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                <MessageStrip
                    text="{i18n>projectConfigurationOverviewHint}"
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginTop"
                    width="100%">
                </MessageStrip>
            </VBox>
        </content>
    </Page>
</mvc:View>
