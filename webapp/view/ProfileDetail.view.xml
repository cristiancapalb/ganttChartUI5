<mvc:View
    controllerName="ganttchartdemo.controller.ProfileDetail"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page
        id="profileDetailPage"
        title="{employeeProfile>/employeeName}"
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiResponsiveContentPadding">
        <content>
            <VBox
                class="homeDetailPage sapUiSmallMargin"
                renderType="Bare">
                <ObjectHeader
                    title="{employeeProfile>/employeeName}"
                    intro="{employeeProfile>/role}"
                    icon="sap-icon://person-placeholder"
                    number="{employeeProfile>/utilization}"
                    numberUnit="{i18n>profileOverviewUtilizationUnit}">
                    <attributes>
                        <ObjectAttribute
                            title="{i18n>profileOverviewDepartmentColumn}"
                            text="{employeeProfile>/department}"/>
                        <ObjectAttribute
                            title="{i18n>profileOverviewLocationLabel}"
                            text="{employeeProfile>/location}"/>
                        <ObjectAttribute
                            title="{i18n>profileOverviewAvailabilityLabel}"
                            text="{employeeProfile>/availability}"/>
                    </attributes>
                    <statuses>
                        <ObjectStatus
                            text="{i18n>profileOverviewStatusText}"
                            state="Success"/>
                    </statuses>
                </ObjectHeader>
                <Panel
                    headerText="{i18n>profileDetailSkillsTitle}"
                    class="sapUiSmallMarginTop"
                    width="100%">
                    <List
                        id="employeeSkillsList"
                        items="{employeeProfile>/skills}">
                        <CustomListItem>
                            <HBox
                                class="employeeProfileLevelRow"
                                alignItems="Center"
                                justifyContent="SpaceBetween"
                                renderType="Bare">
                                <Text text="{employeeProfile>name}"/>
                                <HBox
                                    alignItems="Center"
                                    renderType="Bare">
                                    <RatingIndicator
                                        value="{employeeProfile>level}"
                                        maxValue="5"
                                        displayOnly="true"
                                        iconSize="1rem"
                                        class="sapUiTinyMarginEnd"/>
                                    <Text
                                        text="{path: 'employeeProfile>level', formatter: '.formatLevelText'}"
                                        wrapping="false"
                                        class="employeeProfileLevelValue"/>
                                </HBox>
                            </HBox>
                        </CustomListItem>
                    </List>
                </Panel>
                <Panel
                    headerText="{i18n>profileDetailTechnologiesTitle}"
                    class="sapUiSmallMarginTop"
                    width="100%">
                    <List
                        id="employeeTechnologiesList"
                        items="{employeeProfile>/technologies}">
                        <CustomListItem>
                            <HBox
                                class="employeeProfileLevelRow"
                                alignItems="Center"
                                justifyContent="SpaceBetween"
                                renderType="Bare">
                                <Text text="{employeeProfile>name}"/>
                                <HBox
                                    alignItems="Center"
                                    renderType="Bare">
                                    <RatingIndicator
                                        value="{employeeProfile>level}"
                                        maxValue="5"
                                        displayOnly="true"
                                        iconSize="1rem"
                                        class="sapUiTinyMarginEnd"/>
                                    <Text
                                        text="{path: 'employeeProfile>level', formatter: '.formatLevelText'}"
                                        wrapping="false"
                                        class="employeeProfileLevelValue"/>
                                </HBox>
                            </HBox>
                        </CustomListItem>
                    </List>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
