<mvc:View
    controllerName="ganttchartdemo.controller.ProfileOverview"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page
        id="profileOverviewPage"
        title="{i18n>profileOverviewTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiResponsiveContentPadding">
        <content>
            <VBox
                class="homeDetailPage sapUiSmallMargin"
                renderType="Bare">
                <Table
                    id="employeeOverviewTable"
                    width="100%"
                    mode="None"
                    growing="true"
                    growingScrollToLoad="true"
                    items="{profiles>/employees}">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title
                                text="{i18n>profileOverviewEmployeesTitle}"
                                level="H2"/>
                            <ToolbarSpacer/>
                            <SearchField
                                id="employeeSearchField"
                                width="18rem"
                                placeholder="{i18n>profileOverviewSearchPlaceholder}"
                                liveChange=".onFilterEmployees"
                                search=".onFilterEmployees"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column>
                            <Text text="{i18n>profileOverviewEmployeeColumn}"/>
                        </Column>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true">
                            <Text text="{i18n>profileOverviewDepartmentColumn}"/>
                        </Column>
                        <Column
                            minScreenWidth="Desktop"
                            demandPopin="true">
                            <Text text="{i18n>profileOverviewRoleColumn}"/>
                        </Column>
                        <Column
                            minScreenWidth="Desktop"
                            demandPopin="true"
                            hAlign="End">
                            <Text text="{i18n>profileOverviewUtilizationColumn}"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem
                            type="Navigation"
                            vAlign="Middle"
                            press=".onOpenEmployeeProfile">
                            <customData>
                                <core:CustomData
                                    key="employee-id"
                                    value="{profiles>employeeId}"
                                    writeToDom="true"/>
                            </customData>
                            <cells>
                                <VBox renderType="Bare">
                                    <Text
                                        text="{profiles>employeeName}"
                                        wrapping="false"/>
                                    <Text
                                        text="{profiles>location}"
                                        class="employeeProfileMetaText"
                                        wrapping="false"/>
                                </VBox>
                                <Text text="{profiles>department}"/>
                                <Text text="{profiles>role}"/>
                                <ObjectNumber
                                    number="{profiles>utilization}"
                                    unit="%"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
